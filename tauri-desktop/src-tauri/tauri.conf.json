{
  "productName": "Tunisian Accounting ERP",
  "version": "0.1.0",
  "identifier": "com.tunisian.accounting",
  "build": {
    "devUrl": "http://localhost:8000",
    "frontendDist": "http://localhost:8000"
  },
  "app": {
    "windows": [
      {
        "title": "Tunisian Accounting ERP",
        "width": 1400,
        "height": 900,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
